# CCE Backend — Variables d'environnement 
# Copier ce fichier en .env et renseigner les valeurs

# Express
PORT=3000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cce_db
DB_USER=root
DB_PASSWORD=your-mysql-password

# JWT
JWT_SECRET=your-jwt-secret

# Google OAuth 2.0
# Obtenu depuis la Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com